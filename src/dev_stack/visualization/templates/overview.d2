# Base template for dev-stack overview diagrams.
# Keep syntax compatible with D2 v0.7+ (no deprecated style keys).

direction: right
spacing: 3.2

diagram {
	legend: {
		label: "Legend"
		description: "Entry nodes kick off flows, feature blocks transform data, terminals emit insights."
		note: "Status badges: [added], [updated], blank = steady"
	}

